{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "experimentalSortImports": {
    "newlinesBetween": false,
  },
  "experimentalSortPackageJson": {
    "sortScripts": true,
  },
  "ignorePatterns": [
    "packages/core/apps/",
    "packages/core/assets/",
    "packages/core/dist/",
    "packages/core/docs/_layouts/",
    "node_modules/",
    "packages/core/patches/",
    "packages/core/Swabble/",
    "packages/core/vendor/",
  ],
}
